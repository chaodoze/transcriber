# HuggingFace token for pyannote models (required for diarization)
HF_TOKEN=hf_your_token_here

# Whisper model to use (optional, defaults to distil-whisper-large-v3)
WHISPER_MODEL=distil-whisper-large-v3

# Twitter/X API v2 (Bearer token for reading tweets)
TWITTER_BEARER_TOKEN=your_bearer_token_here
